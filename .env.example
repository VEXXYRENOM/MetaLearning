# Meshy API (server-side only — used by Vite dev proxy, not bundled)
MESHY_API_KEY=

# Use demo pipeline without calling Meshy (returns Duck GLB)
VITE_MESHY_MOCK=1

# Optional: override mock GLB URL
# VITE_MOCK_GLB_URL=https://...

# Optional: full URL to Meshy API if you deploy your own proxy
# VITE_MESHY_PROXY_BASE=https://your-proxy.example.com
