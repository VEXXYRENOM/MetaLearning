# MetaLearning — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.

# ── Fal.ai API (Image/3D Generation) ─────────────────────────────────────────
FAL_API_KEY=your_fal_api_key_here

# ── Supabase (Database + Auth) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Paddle (Payments) ─────────────────────────────────────────────────────────
# Client Token: found in Paddle Dashboard > Developer Tools > Authentication
VITE_PADDLE_CLIENT_TOKEN=pdl_live_your_client_token_here
# Price IDs: found in Paddle Dashboard > Catalog > Prices
VITE_PADDLE_PRO_PRICE_ID=pri_your_pro_price_id
VITE_PADDLE_MAX_PRICE_ID=pri_your_max_price_id
# Webhook Secret: found in Paddle Dashboard > Notifications > Webhooks
PADDLE_WEBHOOK_SECRET=pdl_ntfset_your_webhook_secret
# App URL: your production Vercel URL for success/cancel redirects
VITE_APP_URL=https://your-app-domain.vercel.app

# ── Proxy Security (API Secret Header) ────────────────────────────────────────
VITE_PROXY_SECRET=your_strong_random_secret_here
PROXY_CLIENT_SECRET=your_strong_random_secret_here