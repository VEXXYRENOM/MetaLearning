# MetaLearning — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.

# ── Fal.ai API (Image/3D Generation) ─────────────────────────────────────────
FAL_API_KEY=your_fal_api_key_here

# ── Supabase (Database + Auth) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
VITE_STRIPE_PRO_PRICE_ID=price_your_monthly_price_id
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Proxy Security (API Secret Header) ────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Add the SAME value to Vercel environment variables as PROXY_CLIENT_SECRET.
VITE_PROXY_SECRET=your_strong_random_secret_here
PROXY_CLIENT_SECRET=your_strong_random_secret_here