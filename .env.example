# MetaLearning — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.

# ── Fal.ai API (Image/3D Generation) ─────────────────────────────────────────
FAL_API_KEY=your_fal_api_key_here

# ── Supabase (Database + Auth) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Paddle (Payments) ─────────────────────────────────────────────────────────
# Set to "production" for live payments, "sandbox" for testing
VITE_PADDLE_ENVIRONMENT=production
# Client Token: found in Paddle Dashboard > Developer Tools > Authentication
VITE_PADDLE_CLIENT_TOKEN=pdl_live_your_client_token_here
# Price IDs: found in Paddle Dashboard > Catalog > Prices
VITE_PADDLE_PRO_PRICE_ID=pri_your_pro_price_id
VITE_PADDLE_MAX_PRICE_ID=pri_your_max_price_id
VITE_PADDLE_PRO_ANNUAL_PRICE_ID=pri_your_pro_annual_id
VITE_PADDLE_MAX_ANNUAL_PRICE_ID=pri_your_max_annual_id
# Webhook Secret: found in Paddle Dashboard > Notifications > Webhooks
PADDLE_WEBHOOK_SECRET=pdl_ntfset_your_webhook_secret
# App URL: your production Vercel URL for success/cancel redirects
VITE_APP_URL=https://project-ap4pe.vercel.app

## Paddle Go-Live Checklist
# 1. In Paddle Dashboard: activate your account (complete KYC)
# 2. Get LIVE credentials: Client Token, Price IDs, Webhook Secret
# 3. Set VITE_PADDLE_ENVIRONMENT=production in Vercel environment vars
# 4. Set VITE_PADDLE_CLIENT_TOKEN=pdl_live_... (LIVE token, not test)
# 5. Set VITE_PADDLE_PRO_PRICE_ID=pri_... (LIVE price IDs)
# 6. Set VITE_PADDLE_MAX_PRICE_ID=pri_... (LIVE price IDs)
# 7. Set PADDLE_WEBHOOK_SECRET=pdl_ntfset_... (LIVE webhook secret)
# 8. Redeploy on Vercel

# ── Proxy Security (API Secret Header) ────────────────────────────────────────
VITE_PROXY_SECRET=your_strong_random_secret_here
VITE_PROXY_CLIENT_SECRET=your_strong_random_secret_here

# ── Marketing Automation ──────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
CRON_SECRET=your_secure_cron_secret_here