            transparent
            opacity={0.15}
            roughness={0}
            toneMapped={false}
          />
        </mesh>

        {/* ═══ مدار 1 (حلقة نيون) ═══ */}
        <group ref={electronGrp1}>
          <mesh rotation={[Math.PI / 4, 0, 0]}>
            <torusGeometry args={[1.5, 0.025, 16, 100]} />
