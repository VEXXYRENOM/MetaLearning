  color: #ffffff;
}

/* 🌟 Advanced 3D Lab Styles (Step 4) */
.lab-step {
  display: flex;
  flex-direction: column;
  height: 80vh;
  padding: 0;
  overflow: hidden;
  border-radius: 20px;
  background: #0f172a; /* Dark sleek background for contrast */
  color: white;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}

.lab-header {
  padding: 1.5rem 2rem;
  background: rgba(15, 23, 42, 0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255,255,255,0.1);
  z-index: 10;
}

.lab-header .section-title {
  color: #f8fafc;
  margin-bottom: 0.25rem;
}

.text-gray {
  color: #94a3b8;
  font-size: 0.9rem;
  margin: 0;
}

.lab-wrapper {
  display: flex;
  flex: 1;
  position: relative;
  overflow: hidden;
}

.lab-3d-view {
  flex: 1;
  position: relative;
  background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
  cursor: grab;
}

.lab-3d-view:active {
  cursor: grabbing;
}

.lab-badge {
  position: absolute;
  bottom: 20px;
  right: 20px;
  background: rgba(0,0,0,0.6);
  color: #4facfe;
  padding: 0.5rem 1rem;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  backdrop-filter: blur(5px);
  border: 1px solid rgba(79, 172, 254, 0.3);
  pointer-events: none;
}

.lab-controls-panel {
  width: 350px;
  background: rgba(15, 23, 42, 0.75);
  backdrop-filter: blur(20px);
  border-right: 1px solid rgba(255,255,255,0.1);
  padding: 2rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  z-index: 5;
}

.panel-title {
  color: white;
  margin: 0 0 1rem;
  font-size: 1.1rem;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding-bottom: 1rem;
}

.control-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255,255,255,0.03);
  padding: 1rem;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.05);
}

.ctrl-info {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.ctrl-name {
  font-weight: 600;
  font-size: 0.95rem;
  color: #e2e8f0;
}

.ctrl-info small {
  color: #64748b;
  font-size: 0.75rem;
  line-height: 1.3;
}

.small-select {
  background: rgba(0,0,0,0.3);
  border: 1px solid rgba(255,255,255,0.2);
  color: white;
  padding: 0.5rem;
  border-radius: 6px;
  outline: none;
}

.spacer {
  flex: 1;
}

.glow-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border: none;
  box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
  color: #fff;
}

.glow-btn:hover {
  box-shadow: 0 6px 20px rgba(79, 172, 254, 0.6);
  transform: translateY(-2px);
}

/* ========================================================= */
/* PRIORITY 4 & 7: MOBILE SUPPORT (RESPONSIVENESS)           */
/* ========================================================= */
@media (max-width: 768px) {
  .teacher-layout {
    flex-direction: column;
  }
  .teacher-sidebar {
    width: 100%;
    height: auto;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-right: none;
    border-bottom: 1px solid #1e293b;
  }
  .sidebar-profile {
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
  }
  .sidebar-profile h3 { font-size: 0.95rem; }
  .sidebar-profile p { display: none; }
  .btn-logout { padding: 4px 10px; font-size: 0.75rem; }
  .sidebar-tools {
    flex-direction: row;
    gap: 1rem;
  }
  .teacher-main { width: 100%; }
  .teacher-header { padding: 0.75rem 1rem; }
  .header-title { font-size: 1rem; }
  .header-user span { display: none; }
  .teacher-content { padding: 1rem; }
  .quick-actions-row { flex-direction: column; }
  .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  .lab-wrapper { flex-direction: column; }
  .lab-3d-view { height: 280px; }
  .lab-controls-panel { max-height: none; }
  .step-container { padding: 1rem; }
  .subjects-grid { grid-template-columns: repeat(2, 1fr); }
  .levels-flex { flex-direction: column; align-items: center; }
  .review-layout { flex-direction: column; }
  .code-display { font-size: 1.8rem !important; }
  .share-actions { flex-direction: column; width: 100%; }
  .share-actions a,
  .share-actions button { width: 100%; justify-content: center; }
}

@media (max-width: 480px) {
  .gallery-grid { grid-template-columns: 1fr; }
  .hub-container { padding: 0.5rem; }
}
</file>

