            </button>
            <div style={{ textAlign: 'center', color: '#94a3b8', margin: '0 0 16px', fontSize: '0.85rem' }}>
              أو
            </div>
          </>
        )}

        {signupSuccess && (
          <div style={{ padding: "1.5rem", background: "rgba(16,185,129,0.1)",
            border: "1px solid #10b981", borderRadius: "12px",
