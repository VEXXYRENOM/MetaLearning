  "lion": "🦁", "tiger": "🐯", "elephant": "🐘", "giraffe": "🦒", "whale": "🐋", 
  "shark": "🦈", "dinosaur": "🦖", "dragon": "🐉", "unicorn": "🦄", "wolf": "🐺", 
