             : i18n.language.startsWith("fr") ? "fr"
             : i18n.language.startsWith("es") ? "es"
             : "en";

  const [checkoutTier, setCheckoutTier] = useState<Tier | null>(null);

  const handleUpgrade = (tier: Tier) => {
    if (!user) { navigate("/auth"); return; }
    setCheckoutTier(tier);
  };

  const handleSuccess = () => {
