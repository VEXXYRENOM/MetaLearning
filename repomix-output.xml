                border: `1px solid ${plan.border}`,
                borderRadius: "24px", padding: "2rem",
                boxShadow: plan.recommended ? `0 0 60px ${plan.glow}, 0 20px 40px rgba(0,0,0,0.5)` : "0 8px 32px rgba(0,0,0,0.4)"
