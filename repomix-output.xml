.icon-wrap {
  width: 64px;
  height: 64px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.5rem;
}

.wizard-icon {
  background: #eff6ff;
  color: #3b82f6;
}

.image-ai-icon {
  background: rgba(79, 172, 254, 0.15);
  color: #4facfe;
}

.action-card h3 {
  font-size: 1.25rem;
  font-weight: 700;
  margin: 0 0 0.75rem;
  color: #ffffff;
}

.action-card p {
  color: #cbd5e1;
  line-height: 1.6;
  font-size: 0.95rem;
  margin: 0 0 1.5rem;
  flex: 1;
}

/* Gallery Grid in Hub */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.5rem;
}

.gallery-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: rgba(30, 30, 45, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 1rem;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  transition: all 0.2s;
}

.gallery-card:hover {
  border-color: #a78bfa;
  box-shadow: 0 10px 15px rgba(124, 58, 237, 0.1);
  transform: translateY(-2px);
}

.gallery-thumb {
  width: 60px;
  height: 60px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gallery-info {
  display: flex;
  flex-direction: column;
}

.gal-badge {
  font-size: 0.7rem;
  font-weight: 700;
  color: #3b82f6;
  margin-bottom: 0.25rem;
}

.gallery-info h4 {
  margin: 0;
  font-size: 0.95rem;
  font-weight: 700;
  color: #ffffff;
}

/* 🌟 Advanced 3D Lab Styles (Step 4) */
.lab-step {
  display: flex;
  flex-direction: column;
  height: 80vh;
  padding: 0;
  overflow: hidden;
  border-radius: 20px;
  background: #0f172a; /* Dark sleek background for contrast */
  color: white;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}

.lab-header {
  padding: 1.5rem 2rem;
  background: rgba(15, 23, 42, 0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255,255,255,0.1);
  z-index: 10;
}

.lab-header .section-title {
  color: #f8fafc;
  margin-bottom: 0.25rem;
}

.text-gray {
  color: #94a3b8;
  font-size: 0.9rem;
  margin: 0;
}

.lab-wrapper {
  display: flex;
  flex: 1;
  position: relative;
  overflow: hidden;
}

.lab-3d-view {
  flex: 1;
  position: relative;
  background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
  cursor: grab;
}

.lab-3d-view:active {
  cursor: grabbing;
}

.lab-badge {
  position: absolute;
  bottom: 20px;
  right: 20px;
  background: rgba(0,0,0,0.6);
  color: #4facfe;
  padding: 0.5rem 1rem;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  backdrop-filter: blur(5px);
  border: 1px solid rgba(79, 172, 254, 0.3);
  pointer-events: none;
}

.lab-controls-panel {
  width: 350px;
  background: rgba(15, 23, 42, 0.75);
  backdrop-filter: blur(20px);
  border-right: 1px solid rgba(255,255,255,0.1);
  padding: 2rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  z-index: 5;
}

.panel-title {
  color: white;
  margin: 0 0 1rem;
  font-size: 1.1rem;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding-bottom: 1rem;
}

.control-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255,255,255,0.03);
  padding: 1rem;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.05);
}

.ctrl-info {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.ctrl-name {
  font-weight: 600;
  font-size: 0.95rem;
  color: #e2e8f0;
}

.ctrl-info small {
  color: #64748b;
  font-size: 0.75rem;
  line-height: 1.3;
}

.small-select {
  background: rgba(0,0,0,0.3);
  border: 1px solid rgba(255,255,255,0.2);
  color: white;
  padding: 0.5rem;
  border-radius: 6px;
  outline: none;
}

.spacer {
  flex: 1;
}

.glow-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border: none;
  box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
  color: #fff;
}

.glow-btn:hover {
  box-shadow: 0 6px 20px rgba(79, 172, 254, 0.6);
  transform: translateY(-2px);
}
