@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');

:root {
  --bg: #0c1118;
  --panel: #151c28;
  --border: #2a3548;
  --text: #e8edf4;
  --muted: #8b9bb5;
  --accent: #3d9cf0;
  --accent-dim: #2563a8;
  /* MetaLearning OS Palette */
  --meta-bg: #050508;
  --meta-purple: #7c3aed;
  --meta-blue: #06b6d4;
  --meta-glow: #a78bfa;
  --meta-surface: rgba(15, 10, 30, 0.7);
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  margin: 0;
  height: 100%;
  font-family: "Noto Sans Arabic", system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
}

button {
  font-family: inherit;
  cursor: pointer;
}

a {
  color: var(--accent);
}

canvas {
  touch-action: none;
}

/* ——— AR / Dark Mode Homepage Premium Redesign ——— */
.home-ar-layout {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  background: radial-gradient(circle at 50% -20%, #151e3f, #070914 80%);
  color: #e8edf4;
  overflow-x: hidden;
}

/* Navbar */
.home-navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem clamp(1rem, 5vw, 4rem);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.brand {
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -0.5px;
}

.highlight {
  color: #4facfe;
  text-shadow: 0 0 15px rgba(79, 172, 254, 0.5);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 2rem;
}

.nav-links a {
  text-decoration: none;
  font-size: 0.95rem;
  color: #cbd5e1;
  transition: color 0.3s;
}

.nav-links a:hover { color: #ffffff; }

.nav-btn {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  padding: 0.5rem 1.25rem;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 600;
  color: #fff;
  transition: all 0.3s ease;
}

.nav-btn:hover {
  background: #ffffff;
  color: #070914;
  box-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
}

/* Hero Section */
.hero-section {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  align-items: center;
  gap: 3rem;
  padding: 5rem clamp(1rem, 5vw, 4rem) 6rem;
  min-height: 80vh;
}

@media (max-width: 900px) {
  .hero-section { grid-template-columns: 1fr; text-align: center; }
}

.hero-content {
  z-index: 10;
}

.glow-badge {
  display: inline-block;
  padding: 0.4rem 1rem;
  background: rgba(79, 172, 254, 0.1);
  border: 1px solid rgba(79, 172, 254, 0.3);
  border-radius: 999px;
  color: #4facfe;
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
  box-shadow: 0 0 20px rgba(79, 172, 254, 0.15);
}

.hero-title {
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 900;
  line-height: 1.2;
  margin: 0 0 1.5rem;
}

.text-gradient {
  background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-description {
  font-size: 1.1rem;
  color: #94a3b8;
  line-height: 1.8;
  max-width: 600px;
  margin-bottom: 2.5rem;
}

@media (max-width: 900px) { .hero-description { margin: 0 auto 2.5rem; } }

.hero-buttons {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}

@media (max-width: 900px) { .hero-buttons { justify-content: center; } }

.btn-ar-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #000;
  padding: 1rem 1.75rem;
  border-radius: 12px;
  font-size: 1.05rem;
  font-weight: 800;
  text-decoration: none;
  box-shadow: 0 10px 30px rgba(0, 242, 254, 0.4);
  transition: transform 0.3s, box-shadow 0.3s;
}

.btn-ar-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 40px rgba(0, 242, 254, 0.6);
}

.btn-ar-secondary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255,  255, 255, 0.15);
  color: #ffffff;
  padding: 1rem 1.75rem;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s;
}

.btn-ar-secondary:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: #4facfe;
  color: #4facfe;
}

/* Hologram Visual */
.hero-visual {
  display: flex;
  justify-content: center;
  align-items: center;
  perspective: 1000px;
}

.hologram-effect {
  position: relative;
  width: 300px;
  height: 300px;
  display: flex;
  justify-content: center;
  align-items: center;
  transform-style: preserve-3d;
  animation: float-holo 6s ease-in-out infinite;
}

.holo-ring {
  position: absolute;
  border-radius: 50%;
  border: 2px dashed rgba(79, 172, 254, 0.4);
  animation: spin-ring linear infinite;
}

.r1 { width: 100%; height: 100%; animation-duration: 20s; }
.r2 { width: 75%; height: 75%; border: 1px solid rgba(0, 242, 254, 0.6); animation-duration: 15s; animation-direction: reverse; }
.r3 { width: 50%; height: 50%; border: 3px solid rgba(0, 242, 254, 0.2); animation-duration: 10s; }

.holo-icon {
  color: #00f2fe;
  filter: drop-shadow(0 0 20px #00f2fe);
}

@keyframes spin-ring { 100% { transform: rotate(360deg) rotateX(20deg); } }
@keyframes float-holo {
  0%, 100% { transform: translateY(0) rotateX(10deg); }
  50% { transform: translateY(-20px) rotateX(-5deg); filter: drop-shadow(0 0 30px rgba(0,242,254,0.4)); }
}

/* Features Section */
.features-section {
  padding: 5rem clamp(1rem, 5vw, 4rem);
