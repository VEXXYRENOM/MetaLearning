                  className="ai-progress-fill"
                  style={{
                    width: `${Math.max(3, sf3dProgress)}%`,
                    background: "linear-gradient(90deg, #7c3aed, #a855f7, #c084fc)",
                    boxShadow: "0 0 12px #a855f7",
