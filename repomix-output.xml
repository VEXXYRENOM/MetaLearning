// ─── خريطة الإيموجي للرسم المحلي (يتحول لمجسم 3D) ─────────────────────────
const keywordToEmoji: Record<string, string> = {
  "car": "🚗", "sports car": "🏎️", "airplane": "✈️", "train": "🚂", "bicycle": "🚲", 
