{
  "rewrites": [
    { "source": "/api/fal/generate-3d",   "destination": "/api/fal/generate-3d.js" },
    { "source": "/api/fal/status",        "destination": "/api/fal/status.js" },
    { "source": "/api/lab-ai",            "destination": "/api/lab-ai.js" },
    { "source": "/api/paddle/webhook",    "destination": "/api/paddle/webhook.js" },
    { "source": "/(.*)",                  "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
